{#
/**
 * @file
 * main-hero.twig — Main Hero SDC component for Canvas.
 *
 * Props:
 *  - badge_text, heading, heading_highlight, description
 *  - feature_title, feature_text, feature_tags
 *  - cta_primary_text / url, cta_secondary_text / url
 *  - stat_1..3 _value / _label
 *  - banner_image_url / alt / link_url
 *  - image_url / alt / link_url / overlay_text
 *  - tooltip_1_text, tooltip_2_label / sub, tooltip_3_label / sub
 */
#}

{% set feature_tag_list = feature_tags ? feature_tags|split(',')|map(t => t|trim) : [] %}

<section{{ attributes.addClass('main-hero') }}>
  <div class="main-hero__container">

    {# ──────────────── GRID ──────────────── #}
    <div class="main-hero__grid">

      {# ── LEFT COLUMN ── #}
      <div class="main-hero__content">

        {% if badge_text %}
          <div class="main-hero__badge">
            <span class="main-hero__badge-dot"></span>
            {{ badge_text }}
          </div>
        {% endif %}

        {% if heading %}
          <h1 class="main-hero__heading">
            {% if heading_highlight %}
              {{ heading|replace({(heading_highlight): '<span class="main-hero__heading-highlight">' ~ heading_highlight ~ '</span>'})|raw }}
            {% else %}
              {{ heading }}
            {% endif %}
          </h1>
        {% endif %}

        {% if description %}
          <p class="main-hero__description">{{ description }}</p>
        {% endif %}

        {% if feature_title or feature_text %}
          <div class="main-hero__feature-card">
            {% if feature_title %}
              <p class="main-hero__feature-title">{{ feature_title }}</p>
            {% endif %}
            {% if feature_text %}
              <p class="main-hero__feature-text">{{ feature_text }}</p>
            {% endif %}
            {% if feature_tag_list %}
              <ul class="main-hero__feature-tags">
                {% for tag in feature_tag_list %}
                  <li class="main-hero__feature-tag">{{ tag }}</li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}

        {% if cta_primary_text or cta_secondary_text %}
          <div class="main-hero__actions">
            {% if cta_primary_text %}
              <a href="{{ cta_primary_url ?: '#' }}" class="main-hero__cta main-hero__cta--primary">
                {{ cta_primary_text }}
              </a>
            {% endif %}
            {% if cta_secondary_text %}
              <a href="{{ cta_secondary_url ?: '#' }}" class="main-hero__cta main-hero__cta--secondary">
                {{ cta_secondary_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}

      </div>
      {# END LEFT COLUMN #}

      {# ── RIGHT COLUMN ── #}
      <div class="main-hero__media">

        {# Banner Image (top) #}
        {% if banner_image %}
          {% if banner_link_url %}
            <a href="{{ banner_link_url }}" class="main-hero__banner" target="_blank" rel="noopener noreferrer">
              <img src="{{ banner_image ? file_url(banner_image|replace({'%20': ' ', '%2520': ' '})) : '' }}" alt="{{ banner_image_alt ?: '' }}" class="main-hero__banner-img" loading="lazy" />
            </a>
          {% else %}
            <div class="main-hero__banner">
              <img src="{{ banner_image ? file_url(banner_image|replace({'%20': ' ', '%2520': ' '})) : '' }}" alt="{{ banner_image_alt ?: '' }}" class="main-hero__banner-img" loading="lazy" />
            </div>
          {% endif %}
        {% endif %}

        {# Main image card (bottom) #}
        <div class="main-hero__image-card">
          {% if image_link_url %}
            <a href="{{ image_link_url }}" class="main-hero__image-link" target="_blank" rel="noopener noreferrer">
          {% endif %}

          {% if image %}
            <img src="{{ file_url(image|replace({'%20': ' ', '%2520': ' '})) }}" alt="{{ image_alt ?: '' }}" class="main-hero__image" loading="lazy" />
          {% else %}
            <div class="main-hero__image-placeholder"></div>
          {% endif %}


          {% if image_overlay_text %}
            <div class="main-hero__image-overlay">
              <p class="main-hero__overlay-text">{{ image_overlay_text }}</p>
            </div>
          {% endif %}

          {% if image_link_url %}
            </a>
          {% endif %}

          {# Floating Tooltips #}
          {% if tooltip_1_text %}
            <div class="main-hero__tooltip main-hero__tooltip--tl">
              <span class="main-hero__tooltip-icon main-hero__tooltip-icon--check">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </span>
              <span>{{ tooltip_1_text }}</span>
            </div>
          {% endif %}

          {% if tooltip_2_label %}
            <div class="main-hero__tooltip main-hero__tooltip--mr">
              <span class="main-hero__tooltip-value">{{ tooltip_2_label }}</span>
              {% if tooltip_2_sub %}<span class="main-hero__tooltip-sub">{{ tooltip_2_sub }}</span>{% endif %}
            </div>
          {% endif %}

          {% if tooltip_3_label %}
            <div class="main-hero__tooltip main-hero__tooltip--br">
              <span class="main-hero__tooltip-icon main-hero__tooltip-icon--brand">SC</span>
              <div>
                <strong class="main-hero__tooltip-value">{{ tooltip_3_label }}</strong>
                {% if tooltip_3_sub %}<span class="main-hero__tooltip-sub">{{ tooltip_3_sub }}</span>{% endif %}
              </div>
            </div>
          {% endif %}

        </div>
        {# END image card #}

      </div>
      {# END RIGHT COLUMN #}

    </div>
    {# END GRID #}

    {# ── STATS ROW ── #}
    {% if stat_1_value or stat_2_value or stat_3_value %}
      <div class="main-hero__stats">
        {% for i in 1..3 %}
          {% set val   = attribute(_context, 'stat_' ~ i ~ '_value') %}
          {% set label = attribute(_context, 'stat_' ~ i ~ '_label') %}
          {% if val %}
            <div class="main-hero__stat">
              <span class="main-hero__stat-value">{{ val }}</span>
              <span class="main-hero__stat-label">{{ label }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

  </div>
</section>
