{{ attach_library('seed_theme/about-hero') }}

<section class="py-12 md:py-20 bg-seed-gray-900 relative overflow-hidden min-h-[350px] lg:min-h-[450px] flex items-center">
  {# Background texture #}
  <div class="absolute inset-0 opacity-20">
    {% if background_image %}
      <img src="{{ background_image }}" alt="Digital background" class="w-full h-full object-cover" />
    {% else %}
      <img src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=1920&q=80" alt="Digital background" class="w-full h-full object-cover" />
    {% endif %}
  </div>
  
  <div class="container-custom relative z-10 w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-center">
      {# Left Column - WHY Content #}
      <div class="relative bg-white rounded-2xl p-6 md:p-10 lg:p-12 shadow-[10px_10px_0_0_rgb(34,211,238)] transition-transform duration-300 hover:scale-[1.02] animate-fade-in min-h-[320px] md:min-h-[380px]">
        <h1 class="font-heading font-bold text-seed-gray-900 mb-4 md:mb-6 leading-tight text-2xl md:text-4xl lg:text-[2.5rem] xl:text-5xl text-balance">
          {{ title_regular|default('Transformamos negocios con soluciones') }} 
          <span class="text-seed-blue-600">{{ title_highlight|default('Drupal') }}</span> 
          {{ title_end|default('de alto desempeño') }}
        </h1>
        <p class="text-[14px] md:text-[16px] lg:text-[18px] text-seed-gray-700 leading-relaxed min-h-[100px] md:min-h-[120px] type-writer-text"
           data-about-hero-typewriter
           data-full-text="{{ description|default('Impulsamos la transformación digital de las organizaciones. Creemos que la tecnología debe ser un activo estratégico que potencie el crecimiento, la eficiencia y la sostenibilidad del negocio.') }}"
           data-highlight-words="{{ highlight_words|default('transformación,digital,tecnología,estratégico,crecimiento') }}">
        </p>
      </div>

      {# Right Column - Visual with Image #}
      <div class="hidden lg:block relative animate-fade-in">
        <div class="relative">
          {# Main Image #}
          <div class="w-full h-[400px] bg-gradient-to-r from-seed-blue-100 to-seed-orange-100 rounded-2xl overflow-hidden shadow-2xl relative">
            {% if main_image %}
              <img src="{{ main_image }}" alt="Equipo de desarrollo" class="w-full h-full object-cover" />
            {% else %}
              <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="Equipo de desarrollo" class="w-full h-full object-cover" />
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
          </div>

          {# Floating Cards #}
          <div class="absolute top-6 -left-4 bg-white p-4 rounded-xl shadow-lg hover:scale-105 transition-transform duration-300">
            <div class="flex items-center space-x-3">
              <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
              <span class="text-sm font-medium text-seed-gray-700">Drupal Certified</span>
            </div>
          </div>

          <div class="absolute bottom-6 -right-4 bg-white p-5 rounded-xl shadow-lg hover:scale-105 transition-transform duration-300">
            <div class="flex items-center space-x-3">
              <div class="w-10 h-10 bg-cyan-500 rounded-lg flex items-center justify-center">
                <span class="text-white text-sm font-bold">+{{ years_experience|default('18') }}</span>
              </div>
              <div>
                <span class="text-sm font-medium text-seed-gray-700 block">Años</span>
                <span class="text-xs text-seed-gray-500">Experiencia</span>
              </div>
            </div>
          </div>

          <div class="absolute top-1/2 -right-3 bg-gradient-to-r from-seed-blue-500 to-seed-blue-600 p-3 rounded-lg shadow-lg hover:scale-105 transition-transform duration-300">
            <div class="text-white text-center">
              <div class="text-lg font-bold">{{ projects_count|default('150+') }}</div>
              <div class="text-xs">Proyectos</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    {# Image on mobile - below the box #}
    <div class="lg:hidden mt-8 relative">
      <div class="w-full h-[250px] rounded-xl overflow-hidden shadow-xl">
        {% if main_image %}
          <img src="{{ main_image }}" alt="Equipo de desarrollo" class="w-full h-full object-cover" />
        {% else %}
          <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80" alt="Equipo de desarrollo" class="w-full h-full object-cover" />
        {% endif %}
      </div>
    </div>
  </div>
</section>
