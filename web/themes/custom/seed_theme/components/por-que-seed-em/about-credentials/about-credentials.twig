{{ attach_library('seed_theme/about-credentials') }}

<section class="py-12 md:py-16 bg-white">
  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 max-w-3xl mx-auto">
      <h2 class="font-heading font-bold text-seed-gray-900 mb-4 text-2xl md:text-3xl lg:text-4xl">
        {{ section_title|default('Credenciales que nos') }}
        <span class="text-seed-blue-600 pb-1 border-b-4 border-seed-blue-600 inline-block">{{ section_title_highlight|default('respaldan') }}</span>
      </h2>
      <p class="text-seed-gray-700 text-[14px] md:text-lg">
        {{ section_description|default('Experiencia, certificaciones y respaldo tecnológico que garantizan resultados.') }}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% set final_items = [
        {
          'title': item_1_title|default('+18 años de experiencia'),
          'description': item_1_desc|default('Soluciones digitales de alto desempeño para empresas líderes.'),
          'icon_svg': item_1_icon|default('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>'),
          'is_wide': false
        },
        {
          'title': item_2_title|default('Drupal Platinum Certified'),
          'description': item_2_desc|default('Primeros en Colombia y referentes en Latinoamérica.'),
          'icon_svg': item_2_icon|default('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-award"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>'),
          'badge_text': item_2_badge|default('Platinum'),
          'is_wide': false
        },
        {
          'title': item_3_title|default('Asociación Drupal'),
          'description': item_3_desc|default('Contribuyentes activos de la Asociación Mundial y fundadores de Drupal Colombia.'),
          'icon_svg': item_3_icon|default('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>'),
          'is_wide': false
        },
        {
          'title': item_4_title|default('Infraestructura AWS'),
          'description': item_4_desc|default('Plataformas robustas y escalables sobre Amazon Web Services.'),
          'icon_svg': item_4_icon|default('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cloud"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>'),
          'is_wide': false
        },
        {
          'title': item_5_title|default('Metodologías de calidad'),
          'description': item_5_desc|default('Enfocadas en calidad, seguridad, performance y transferencia de conocimiento.'),
          'icon_svg': item_5_icon|default('<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>'),
          'is_wide': item_5_wide|default(true)
        }
      ] %}

      {% for item in final_items %}
        <div class="group bg-white border-2 border-seed-gray-200 rounded-xl p-6 hover:bg-seed-gray-900 hover:border-cyan-400 transition-all duration-300 {{ item.is_wide ? 'md:col-span-2 lg:col-span-2' : '' }}">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-seed-blue-100 rounded-lg flex items-center justify-center group-hover:bg-cyan-400/20 transition-colors duration-300">
              {% if item.icon_svg %}
                <span class="w-6 h-6 text-cyan-500 group-hover:text-cyan-400 transition-colors duration-300 [&>svg]:w-full [&>svg]:h-full">{{ item.icon_svg|raw }}</span>
              {% else %}
                <div class="w-6 h-6 bg-cyan-500 rounded-sm"></div>
              {% endif %}
            </div>
            <div>
              <h3 class="text-lg font-heading font-bold text-seed-gray-900 group-hover:text-white mb-2 transition-colors duration-300">
                {{ item.title }}
              </h3>
              <p class="text-sm text-seed-gray-600 group-hover:text-seed-gray-300 transition-colors duration-300 {{ item.badge_text ? 'mb-3' : '' }}">
                {{ item.description }}
              </p>
              {% if item.badge_text %}
                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-transparent bg-cyan-400 text-seed-gray-900 hover:bg-cyan-300">
                  {{ item.badge_text }}
                </span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
