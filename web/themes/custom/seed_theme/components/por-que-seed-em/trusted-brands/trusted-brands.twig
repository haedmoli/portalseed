{{ attach_library('seed_theme/trusted-brands') }}

<section class="relative py-8 md:py-16 bg-white overflow-hidden">
  <div class="absolute top-1/4 left-10 w-2 h-2 rounded-full bg-seed-blue-500/20"></div>
  <div class="absolute bottom-1/3 right-1/3 w-3 h-3 rounded-full bg-seed-blue-500/15"></div>

  <div class="container-custom mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-12">
      <div class="text-center lg:text-left lg:w-2/5">
        <h2 class="font-heading font-bold text-seed-gray-900 mb-4 text-2xl md:text-3xl lg:text-4xl">
          {{ section_title_regular|default('Marcas y alianzas que') }} <span class="text-seed-blue-600 inline-block border-b-4 border-seed-blue-600 pb-1">{{ section_title_highlight|default('respaldan') }}</span> nuestra experiencia
        </h2>
        <p class="text-[14px] md:text-lg text-seed-gray-600 max-w-2xl lg:max-w-none">
          {{ section_description|default('Trabajamos junto a empresas líderes y comunidades tecnológicas que confían en nuestra capacidad y trayectoria.') }}
        </p>
      </div>

      <div class="relative w-full lg:w-3/5">
        <div class="absolute left-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-r from-white via-white/80 to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-l from-white via-white/80 to-transparent z-10 pointer-events-none"></div>
        
        <div class="overflow-hidden relative flex">
          <div class="flex animate-scroll-continuous hover:[animation-play-state:paused] w-max items-center">
            
            {% set render_logos = [] %}
            {% if logo_1 %}{% set render_logos = render_logos|merge([logo_1]) %}{% endif %}
            {% if logo_2 %}{% set render_logos = render_logos|merge([logo_2]) %}{% endif %}
            {% if logo_3 %}{% set render_logos = render_logos|merge([logo_3]) %}{% endif %}
            {% if logo_4 %}{% set render_logos = render_logos|merge([logo_4]) %}{% endif %}
            {% if logo_5 %}{% set render_logos = render_logos|merge([logo_5]) %}{% endif %}
            {% if logo_6 %}{% set render_logos = render_logos|merge([logo_6]) %}{% endif %}
            {% if logo_7 %}{% set render_logos = render_logos|merge([logo_7]) %}{% endif %}
            {% if logo_8 %}{% set render_logos = render_logos|merge([logo_8]) %}{% endif %}

            {% if render_logos is empty %}
              {% set render_logos = [
                'https://seedem.co/sites/default/files/2021-04/segib_0.png',
                'https://seedem.co/sites/default/files/2021-05/fundacion-exito.png',
                'https://seedem.co/sites/default/files/2024-03/poli.png',
                'https://seedem.co/sites/default/files/2021-05/totto.png'
              ] %}
            {% endif %}

            {% for collection in 1..2 %}
              {% for logo in render_logos %}
                <div class="flex-shrink-0 mx-4 md:mx-6 group">
                  <img src="{{ file_url(logo|trim) }}" class="h-16 md:h-24 max-w-[200px] object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 cursor-pointer transition-all duration-500" alt="Brand Logo" />
                </div>
              {% endfor %}
            {% endfor %}
            
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
