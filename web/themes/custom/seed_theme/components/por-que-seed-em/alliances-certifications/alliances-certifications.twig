{{ attach_library('seed_theme/alliances-certifications') }}

<section class="py-8 md:py-16 bg-seed-gray-900 relative overflow-hidden">
  {# Decorative elements #}
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <svg class="absolute top-20 left-10 w-24 h-24 text-seed-blue-500 opacity-[0.15]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    <svg class="absolute top-32 right-20 w-28 h-28 text-seed-blue-400 opacity-[0.14]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
    <div class="absolute inset-0 bg-gradient-to-br from-seed-blue-950/20 via-transparent to-seed-gray-900/40"></div>
  </div>

  <div class="container-custom relative z-10 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5 animate-slide-up">
        <h2 class="font-heading font-bold text-white mb-6 text-2xl md:text-3xl lg:text-4xl">
          {{ section_title_regular|default('Alianzas y') }} <span class="text-cyan-400 pb-1 border-b-4 border-cyan-400 inline-block">{{ section_title_highlight|default('Certificaciones') }}</span>
        </h2>
        <p class="text-[14px] md:text-lg text-seed-gray-300">
          {{ section_description|default('Trabajamos de la mano con las mejores plataformas y comunidades tecnológicas para garantizar soluciones de calidad.') }}
        </p>
      </div>

      <div class="lg:col-span-7 animate-fade-in">
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 lg:gap-12">
            <div class="transition-transform duration-300 hover:scale-110 flex-shrink-0">
              <img src="{{ logo_1_url ? file_url(logo_1_url) : '/themes/custom/seed_theme/assets/drupal-certified-partner.png' }}" class="h-20 md:h-32 lg:h-40 w-auto object-contain" alt="Partner 1" />
            </div>
            <div class="transition-transform duration-300 hover:scale-110 flex-shrink-0">
              <img src="{{ logo_2_url ? file_url(logo_2_url) : '/themes/custom/seed_theme/assets/drupal-ai-gold-sponsor.png' }}" class="h-20 md:h-32 lg:h-40 w-auto object-contain" alt="Partner 2" />
            </div>
            <div class="transition-transform duration-300 hover:scale-110 flex-shrink-0">
              <img src="{{ logo_3_url ? file_url(logo_3_url) : '/themes/custom/seed_theme/assets/logo-aws.png' }}" class="h-20 md:h-32 lg:h-40 w-auto object-contain" alt="Partner 3" />
            </div>
        </div>
      </div>
    </div>
  </div>
</section>
