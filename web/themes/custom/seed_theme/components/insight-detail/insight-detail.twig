{#
/**
 * @file
 * insight-detail.twig
 */
#}
<article{{ attributes.addClass('insight-detail-component', 'w-full', 'max-w-4xl', 'mx-auto', 'bg-white', 'shadow-sm', 'rounded-lg', 'overflow-hidden') }}>
  
  {# Image Top Banner #}
  {% if banner_image %}
    <div class="insight-detail-image w-full max-h-[500px] bg-gray-50 flex justify-center overflow-hidden relative rounded-t-lg">
      <img src="{{ file_url(banner_image) }}" alt="{{ banner_image_alt|default(title) }}" class="max-w-full h-auto max-h-[500px] object-contain" />
    </div>
  {% endif %}

  <div class="insight-detail-content px-6 md:px-12 py-8 md:py-12">
    {# Título Principal #}
    {% if title %}
      <h1 class="text-3xl md:text-5xl font-extrabold text-[#006699] mb-6 leading-tight" style="color: #0b5c87; font-family: 'Inter', sans-serif;">
        {{ title }}
      </h1>
    {% endif %}

    {# Meta: Date & Share #}
    <div class="insight-detail-meta flex justify-between items-center text-gray-500 mb-10 pb-6 border-b border-gray-100">
      
      {% if publish_date %}
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="text-sm font-medium">
            {{ publish_date|date('d \\d\\e F, Y') }}
          </span>
        </div>
      {% endif %}

      {# Custom Share Popover #}
      <div class="insight-share-container" style="position: relative; display: flex; align-items: center;">
        <div class="insight-share-trigger" style="cursor: pointer; display: flex; align-items: center; justify-content: center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
        </div>

        <div class="insight-share-popover">
          {# Facebook #}
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ url('<current>')|url_encode }}" target="_blank" rel="noopener" class="insight-share-icon insight-share-icon--facebook" title="Compartir en Facebook">
            <svg width="20" height="20" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.324v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
          </a>
          {# Twitter/X #}
          <a href="https://twitter.com/intent/tweet?url={{ url('<current>')|url_encode }}&text={{ title|url_encode }}" target="_blank" rel="noopener" class="insight-share-icon insight-share-icon--twitter" title="Compartir en X">
            <svg width="20" height="20" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.134l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          {# LinkedIn #}
          <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ url('<current>')|url_encode }}" target="_blank" rel="noopener" class="insight-share-icon insight-share-icon--linkedin" title="Compartir en LinkedIn">
            <svg width="20" height="20" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          {# Instagram #}
          <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="insight-share-icon insight-share-icon--instagram" title="Visítanos en Instagram">
            <svg width="20" height="20" class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>
      
    </div>

    {# Body Content #}
    {% if content %}
      <div class="prose prose-lg md:prose-xl prose-blue max-w-none text-gray-700 leading-relaxed font-sans">
        {{ content }}
      </div>
    {% endif %}

  </div>
</article>
