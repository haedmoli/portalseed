{# insight-hero.twig #}
<section {{ attributes.addClass('py-8 sm:py-10 md:py-16 lg:py-20 bg-seed-blue-950 relative overflow-hidden min-h-[250px] sm:min-h-[280px] md:min-h-[350px] lg:min-h-[400px] flex items-center') }}>
  {# Background texture #}
  {% if bg_image_url %}
    <div class="absolute inset-0 opacity-20 pointer-events-none">
      <img src="{{ bg_image_url }}" alt="" class="w-full h-full object-cover">
    </div>
  {% endif %}

  {# Decorative elements #}
  <div class="absolute inset-0 overflow-hidden pointer-events-none hidden sm:block">
    <div class="absolute -top-16 -right-16 w-40 md:w-64 h-40 md:h-64 border-2 border-seed-blue-400/20 rounded-full"></div>
    <div class="absolute -bottom-20 -left-20 w-32 md:w-56 h-32 md:h-56 border-2 border-cyan-400/15 rounded-full"></div>
    <div class="absolute top-1/4 right-1/5 w-2 h-2 bg-seed-blue-400 rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/4 left-1/5 w-2 h-2 bg-cyan-400 rounded-full animate-pulse delay-75"></div>
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-seed-blue-950/20 via-transparent to-seed-blue-950/40 pointer-events-none"></div>

  <div class="container relative z-10 w-full px-4 sm:px-6 mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 lg:gap-12 items-center">
      {# Left Column - Content Card #}
      <div class="relative bg-white rounded-xl sm:rounded-2xl p-5 sm:p-6 md:p-8 lg:p-12 shadow-[6px_6px_0_0_rgb(34,211,238)] sm:shadow-[10px_10px_0_0_rgb(34,211,238)] transition-transform duration-300 hover:scale-[1.01] md:hover:scale-[1.02] animate-fade-in min-h-[200px] sm:min-h-[240px] md:min-h-[280px] lg:min-h-[320px]">
        <h1 class="font-bold text-seed-blue-950 mb-3 sm:mb-4 md:mb-6 leading-tight text-[1.5rem] sm:text-[1.75rem] md:text-[2rem]">
          {{ title_prefix }}<span class="text-seed-blue-600">{{ title_highlight }}</span>
        </h1>
        <p class="insight-hero-typewriter text-[13px] sm:text-[14px] md:text-[16px] lg:text-[18px] text-seed-blue-900/80 leading-relaxed min-h-[60px] sm:min-h-[70px] md:min-h-[80px] lg:min-h-[100px]" 
           data-text="{{ description }}">
          <span class="typewriter-content"></span><span class="animate-pulse border-r-2 border-seed-blue-600 ml-1"></span>
        </p>
      </div>

      {# Right Column - Hero Image #}
      <div class="hidden md:flex relative animate-fade-in items-center justify-center">
        <div class="relative w-full max-h-[350px] bg-gradient-to-r from-seed-blue-100 to-purple-100 rounded-2xl shadow-2xl overflow-hidden aspect-[16/9]">
          {% if hero_image %}
            <img src="{{ hero_image }}" alt="{{ title_prefix }}{{ title_highlight }}" class="w-full h-full object-cover">
          {% else %}
             <div class="w-full h-full bg-seed-blue-900/10 flex items-center justify-center">
                <span class="text-seed-blue-900/20 text-4xl">Seed EM Insights</span>
             </div>
          {% endif %}
          
          <div class="absolute bottom-4 left-4 right-4 bg-seed-blue-950/75 backdrop-blur-md px-4 py-3 rounded-xl border border-white/10">
            <div class="flex items-center gap-3">
              <span class="text-3xl font-extrabold bg-gradient-to-r from-cyan-300 to-cyan-400 bg-clip-text text-transparent leading-none drop-shadow-[0_0_8px_rgba(34,211,238,0.5)]">{{ counter_value }}</span>
              <div class="w-px h-6 bg-white/20"></div>
              <span class="text-white/90 text-xs font-medium uppercase tracking-widest">{{ counter_label }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
