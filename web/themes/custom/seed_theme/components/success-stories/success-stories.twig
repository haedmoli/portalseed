{{ attach_library('seed_theme/success-stories') }}

<section class="success-stories py-16 md:py-24 bg-[#F8FAFC]">
  <div class="container-custom mx-auto px-4">
    
    {# Header #}
    <div class="max-w-3xl mx-auto text-center mb-16 animate-fade-in">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-extrabold text-[#0F172A] mb-6">
        {{ section_title }} <span class="text-[#00C2FF]">{{ section_title_highlight }}</span> que nos respaldan
      </h2>
      <p class="text-slate-500 text-lg">
        {{ section_description }}
      </p>
    </div>

    {# Cards Grid #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      {% for i in 1..3 %}
        {% set title = attribute(_context, 'c' ~ i ~ '_title') %}
        {% set desc = attribute(_context, 'c' ~ i ~ '_desc') %}
        {% set tags = attribute(_context, 'c' ~ i ~ '_tags')|split(',') %}
        {% set image = attribute(_context, 'c' ~ i ~ '_image') %}
        {% set url = attribute(_context, 'c' ~ i ~ '_url') %}
        {% set color = attribute(_context, 'c' ~ i ~ '_color') %}

        <article class="case-card animate-slide-up" style="border-top-color: {{ color }}; animation-delay: {{ i * 150 }}ms;">
          
          {# Image Area #}
          <div class="image-wrapper group">
            {% if image %}
              <img src="{{ file_url(image) }}" alt="{{ title }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            {% else %}
              <div class="absolute inset-0 flex items-center justify-center text-slate-300">
                <svg class="w-16 h-16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </div>
            {% endif %}
          </div>

          {# Content #}
          <div class="content flex-grow flex flex-col">
            <h3>{{ title }}</h3>
            <p class="mb-6">{{ desc }}</p>

            {# Tags #}
            <div class="flex flex-wrap gap-2 mb-8 mt-auto">
              {% for tag in tags %}
                <span class="tag">
                  {{ tag|trim }}
                </span>
              {% endfor %}
            </div>

            {# Action #}
            <a href="{{ url }}" class="btn-case group">
              Ver caso completo
              <div class="arrow-circle transition-all">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          </div>

        </article>
      {% endfor %}

    </div>

    {# Footer Action #}
    <div class="mt-16 text-center">
      <a href="/casos" class="btn-all-cases">
        Ver todos los casos
      </a>
    </div>

  </div>
</section>
