{{ attach_library('seed_theme/contact-hero') }}

<section class="relative bg-seed-gray-900 overflow-hidden pt-20 pb-12 md:pt-32 md:pb-20">
  {# Decorative Background Elements - Ref: Contacto.tsx #}
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <img src="/themes/custom/seed_theme/assets/icon-encrypted.svg" alt="" class="absolute top-20 left-10 w-32 h-32 opacity-[0.18]" />
    <img src="/themes/custom/seed_theme/assets/icon-flame.svg" alt="" class="absolute top-32 left-[55%] w-32 h-32 opacity-[0.16]" />
    <img src="/themes/custom/seed_theme/assets/icon-layer-1.svg" alt="" class="absolute top-1/3 right-1/4 w-24 h-24 opacity-[0.18]" />
    <img src="/themes/custom/seed_theme/assets/icon-layer-2.svg" alt="" class="absolute bottom-1/4 left-1/3 w-28 h-28 opacity-[0.16]" />
    <img src="/themes/custom/seed_theme/assets/icon-subtract.svg" alt="" class="absolute top-1/2 left-1/4 w-20 h-20 opacity-[0.17]" />
    <img src="/themes/custom/seed_theme/assets/icon-layer-3.svg" alt="" class="absolute bottom-1/3 right-1/3 w-24 h-24 opacity-[0.16]" />
    
    <div class="absolute -top-20 -right-20 w-96 h-96 border-2 border-seed-blue-400/20 rounded-full"></div>
    <div class="absolute -bottom-32 -left-32 w-80 h-80 border-2 border-seed-blue-400/10 rounded-full"></div>
    
    <svg class="absolute top-1/4 left-0 w-full h-full opacity-20" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="lineGradient" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="rgb(59, 130, 246)" stop-opacity="0" />
          <stop offset="50%" stop-color="rgb(59, 130, 246)" stop-opacity="0.5" />
          <stop offset="100%" stop-color="rgb(59, 130, 246)" stop-opacity="0" />
        </linearGradient>
      </defs>
      <path d="M 0 100 Q 200 50 400 100 T 800 100" stroke="url(#lineGradient)" stroke-width="2" fill="none" />
      <path d="M 0 300 Q 300 250 600 300 T 1200 300" stroke="url(#lineGradient)" stroke-width="2" fill="none" />
    </svg>
    
    <div class="absolute top-1/3 right-1/4 w-2 h-2 bg-seed-blue-400 rounded-full animate-pulse"></div>
    <div class="absolute bottom-1/3 right-1/3 w-2 h-2 bg-seed-blue-500 rounded-full animate-pulse delay-75"></div>
    <div class="absolute top-2/3 left-1/4 w-2 h-2 bg-seed-blue-400 rounded-full animate-pulse delay-150"></div>
    
    <div class="absolute inset-0 bg-gradient-to-br from-seed-blue-950/30 via-transparent to-seed-gray-900/50"></div>
  </div>

  <div class="container-custom mx-auto px-4 relative z-10">
    <div class="flex flex-col lg:grid lg:grid-cols-[1.5fr_1fr] gap-8 lg:gap-12 max-w-7xl mx-auto items-start">
      
      {# Left Column - Info & Cards #}
      <div class="animate-fade-in w-full">
        <div class="relative w-full lg:w-[85%] mb-12">
          <div class="relative bg-white rounded-2xl p-6 md:p-10 shadow-[10px_10px_0_0_rgb(34,211,238)] transition-transform duration-300 hover:scale-[1.02]">
            <h1 class="text-[32px] md:text-[56px] font-heading font-bold text-seed-gray-900 mb-6 flex items-center gap-4">
              {{ heading|default('Contacto') }}
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-500 w-10 h-10 md:w-14 md:h-14"><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"/><circle cx="12" cy="11" r="3"/></svg>
            </h1>
            <p class="text-[16px] md:text-[18px] text-seed-gray-700 leading-relaxed min-h-[60px] contact-hero-typewriter"
               data-full-text="{{ subheading|default('Si estás buscando ayuda con un proyecto nuevo, una migración a Drupal o solución a un problema específico sobre un sitio existente, no dudes en contactarnos.') }}"
               data-highlight-words="Drupal,solución,proyecto,nuevo,contactarnos">
            </p>
          </div>
        </div>

        {# Contact Bento Grid #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {# Address 1 #}
          <div class="md:col-span-2 lg:col-span-2 bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="text-xs text-seed-gray-300 mb-1">{{ address_1_label|default('Dirección') }}</div>
                <div class="text-sm text-white font-medium">{{ address_1_value|default('Calle 150 No. 21A-14, P2, Bogotá, Colombia') }}</div>
              </div>
            </div>
          </div>
          {# Phone #}
          <a href="{{ phone_url|default('tel:+573118608152') }}" class="bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-400"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div class="text-xs text-seed-gray-300 mb-1">{{ phone_label|default('Teléfono') }}</div>
              <div class="text-sm text-white font-medium">{{ phone_value|default('(+57) 3118608152') }}</div>
            </div>
          </a>
          {# Address 2 #}
          <div class="md:col-span-2 lg:col-span-1 bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
             <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <div class="text-xs text-seed-gray-300 mb-1">{{ address_2_label|default('Oficina Miami') }}</div>
                <div class="text-sm text-white font-medium text-balance">{{ address_2_value|default('4855 W Hillsboro Blvd Suite B3, Coconut Creek, FL 33073') }}</div>
              </div>
            </div>
          </div>
          {# Email #}
          <a href="{{ email_url|default('mailto:info@seedem.co') }}" class="bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-400"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div class="text-xs text-seed-gray-300 mb-1">{{ email_label|default('Correo electrónico') }}</div>
              <div class="text-sm text-white font-medium">{{ email_value|default('info@seedem.co') }}</div>
            </div>
          </a>
          {# Support #}
          <a href="{{ support_url|default('https://seedem.freshdesk.com/support/login') }}" target="_blank" rel="noopener noreferrer" class="bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-xl p-6 hover:bg-white/10 transition-all duration-300">
            <div class="flex flex-col items-center text-center">
              <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-seed-blue-400"><path d="M3 14h3a3 3 0 0 1 3 3v3a3 3 0 0 1-3 3H3a3 3 0 0 1-3-3v-3a3 3 0 0 1 3-3z"/><path d="M15 14h3a3 3 0 0 1 3 3v3a3 3 0 0 1-3 3h-3a3 3 0 0 1-3-3v-3a3 3 0 0 1 3-3z"/><path d="M7 14V4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v10"/></svg>
              </div>
              <div class="text-xs text-seed-gray-300 mb-1">{{ support_label|default('Soporte') }}</div>
              <div class="text-sm text-white font-medium">{{ support_value|default('Centro de soporte') }}</div>
            </div>
          </a>
        </div>
      </div>

      {# Right Column - Form #}
      <div class="animate-fade-in w-full lg:sticky lg:top-24 contact-hero-glass-form">
        <div class="bg-white/5 backdrop-blur-sm border border-seed-blue-400/30 rounded-2xl p-6 md:p-8 hover:bg-white/8 transition-all duration-300 min-h-[400px]">
           {% block form_slot %}
             <div class="text-white/80 font-medium text-center py-12 border-2 border-dashed border-seed-blue-400/50 rounded-xl bg-white/5">
               <span class="block text-2xl mb-2">📥 Área del Webform</span>
               Busca el componente <strong>"Webform"</strong> de Canvas y arrástralo aquí dentro para enlazar tu formulario nativamente.
             </div>
           {% endblock %}
        </div>
      </div>

    </div>
  </div>
</section>
