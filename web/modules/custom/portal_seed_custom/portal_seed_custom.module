<?php

/**
 * @file
 * Primary module hooks for Portal Seed Custom module.
 */

use Drupal\Core\Url;
use Drupal\Core\Language\LanguageInterface;

/**
 * Implements hook_toolbar_alter().
 */
function portal_seed_custom_toolbar_alter(&$items) {
  if (isset($items['canvas'])) {
    // Force the Canvas URL to be non-localized (no /es/ prefix).
    // This fixes the issue where /es/canvas shows a blank page.
    $items['canvas']['tab']['#url'] = Url::fromRoute('canvas.boot.empty', [], [
      'language' => \Drupal::languageManager()->getLanguage(LanguageInterface::LANGCODE_NOT_SPECIFIED),
    ]);
  }
}
