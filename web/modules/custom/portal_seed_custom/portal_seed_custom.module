<?php

/**
 * @file
 * Primary module hooks for Portal Seed Custom module.
 */

use Drupal\Core\Url;
use Drupal\Core\Language\LanguageInterface;

/**
 * Implements hook_toolbar_alter().
 */
function portal_seed_custom_toolbar_alter(&$items) {
  if (isset($items['canvas'])) {
    // Force the Canvas URL to be non-localized (no /es/ prefix).
    // We use fromUserInput and explicitly clear the prefix/language options.
    $items['canvas']['tab']['#url'] = \Drupal\Core\Url::fromUserInput('/canvas', [
      'absolute' => TRUE,
      'prefix' => '',
      'language' => \Drupal::languageManager()->getLanguage(\Drupal\Core\Language\LanguageInterface::LANGCODE_NOT_SPECIFIED),
    ]);
  }
}
